<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:background="@drawable/widget_bg_surface"
    android:minHeight="56dp"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/course_accent"
        android:layout_width="5dp"
        android:layout_height="match_parent"
        android:background="@drawable/widget_bg_accent_primary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="7dp"
        android:paddingEnd="10dp"
        android:paddingBottom="7dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/course_nodes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#66707F"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/course_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#315F89"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/course_badge"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:background="@drawable/widget_bg_badge"
                android:gravity="center"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:textColor="#244E72"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/course_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#20242A"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/course_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#66707F"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
