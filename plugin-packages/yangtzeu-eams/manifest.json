{
  "id": "yangtzeu-eams-js-v1",
  "name": "长江大学教务插件 JS v1",
  "publisher": "Class Schedule Viewer",
  "version": "1.0.0",
  "versionCode": 1000,
  "apiVersion": 2,
  "entry": "main.js",
  "description": "通过 ATrust + EAMS 页面会话抓取长江大学课表，并在 WebView 插件运行时生成课程草稿。",
  "permissions": [
    "web.navigate",
    "network.fetch",
    "schedule.write"
  ],
  "allowedHosts": [
    "cas-yangtzeu-edu-cn.atrust.yangtzeu.edu.cn",
    "authserver.yangtzeu.edu.cn",
    "cas.yangtzeu.edu.cn",
    "ids.yangtzeu.edu.cn",
    "atrust.yangtzeu.edu.cn",
    "vpn.yangtzeu.edu.cn",
    "ehall-yangtzeu-edu-cn-s.atrust.yangtzeu.edu.cn",
    "lp-open-weixin-qq-com.atrust.yangtzeu.edu.cn",
    "open-weixin-qq-com-s.atrust.yangtzeu.edu.cn",
    "res-wx-qq-com-s.atrust.yangtzeu.edu.cn",
    "jwc3-yangtzeu-edu-cn-s.atrust.yangtzeu.edu.cn",
    "jwc3.yangtzeu.edu.cn"
  ],
  "webEngine": {
    "preferred": "system_webview",
    "allowChromium": true,
    "chromiumComponent": "engine.chromium.android"
  },
  "components": [],
  "limits": {
    "timeoutMs": 60000,
    "maxCourses": 1000,
    "maxStorageBytes": 1048576,
    "maxCapturedTextBytes": 1048576,
    "maxOutputBytes": 1048576
  },
  "dataPackVersion": "1"
}
